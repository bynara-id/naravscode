{
  "name": "bynara-vscode",
  "displayName": "ByNara AI",
  "version": "0.70.0",
  "description": "VS Code extension for the ByNara AI coding agent",
  "categories": [
    "AI",
    "Chat"
  ],
  "homepage": "https://github.com/bynara-id/naravscode#readme",
  "bugs": {
    "url": "https://github.com/bynara-id/naravscode/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bynara-id/naravscode.git"
  },
  "publisher": "bynara-id",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts -w",
    "package": "pnpm build && pnpx @vscode/vsce package --no-dependencies",
    "install-local": "pnpm package && code --install-extension *.vsix",
    "release": "node scripts/release.ts",
    "fmt": "oxlint . --fix && oxfmt .",
    "lint": "oxlint . && oxfmt --check .",
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "test": "pnpm lint && pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "~1.105.0",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.9",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rolldown": "^1.0.0-rc.10",
    "vitest": "^4.1.0"
  },
  "contributes": {
    "icons": {
      "bynara-logo": {
        "description": "ByNara logo icon",
        "default": {
          "fontPath": "assets/fonts/pi-icons.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "chatParticipants": [
      {
        "id": "bynara.chat",
        "fullName": "ByNara AI",
        "name": "bynara",
        "description": "Chat with the ByNara AI coding agent",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "bynara.open",
        "title": "ByNara: Open",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      },
      {
        "command": "bynara.openWithFile",
        "title": "ByNara: Open with File",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      },
      {
        "command": "bynara.sendSelection",
        "title": "ByNara: Send Selection"
      },
      {
        "command": "bynara.upgrade",
        "title": "ByNara: Upgrade ByNara CLI and Packages"
      },
      {
        "command": "bynara.openInNewWindow",
        "title": "ByNara: Open in New Window",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      },
      {
        "command": "bynara.signIn",
        "title": "ByNara: Sign in with ByNara"
      },
      {
        "command": "bynara.openChat",
        "title": "ByNara: Open Chat"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "bynara.openWithFile",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "bynara.openWithFile",
          "group": "navigation"
        }
      ]
    },
    "terminal": {
      "profiles": [
        {
          "id": "bynara.terminal-profile",
          "title": "ByNara",
          "icon": "bynara-logo"
        }
      ]
    },
    "configuration": {
      "title": "ByNara",
      "properties": {
        "bynara.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the naracli binary. Leave empty for auto-detection."
        }
      }
    },
    "keybindings": [
      {
        "command": "bynara.open",
        "key": "ctrl+alt+3"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bynara",
          "title": "ByNara",
          "icon": "assets/logo.svg"
        }
      ]
    },
    "views": {
      "bynara": [
        {
          "id": "bynara.home",
          "name": "ByNara",
          "type": "webview"
        }
      ]
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.105.0"
  },
  "packageManager": "pnpm@10.32.1"
}
